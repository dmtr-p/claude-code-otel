# Domain for subdomain routing (e.g., grafana.example.com, otel.example.com)
DOMAIN=example.com

# Cloudflare API tokens (create at https://dash.cloudflare.com/profile/api-tokens)
# CF_DNS_API_TOKEN needs Zone:DNS:Edit permission
# CF_ZONE_API_TOKEN needs Zone:Zone:Read permission (optional if DNS token covers all zones)
CF_DNS_API_TOKEN=your-cloudflare-dns-api-token
CF_ZONE_API_TOKEN=your-cloudflare-zone-api-token

# Docker socket path
# Linux:              /var/run/docker.sock
# Docker Desktop Mac: /Users/<you>/.docker/run/docker.sock
# Colima:             /Users/<you>/.colima/default/docker.sock
DOCKER_SOCK=/var/run/docker.sock

# Let's Encrypt registration email
ACME_EMAIL=you@example.com

# Google OAuth SSO (create at https://console.developers.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Restrict by workspace domain (space-separated) and/or specific emails (space-separated)
# Leave empty to allow any Google account
GOOGLE_ALLOWED_DOMAINS=example.com
GOOGLE_ALLOWED_EMAILS=
# Grafana role mapping (JMESPath expression evaluated against Google userinfo)
# Uses exact email matching — everyone else gets Viewer
GRAFANA_ROLE_MAPPING='Viewer'
# Single admin:
#GRAFANA_ROLE_MAPPING=email == 'admin@example.com' && 'Admin' || 'Viewer'
# Multiple admins:
#GRAFANA_ROLE_MAPPING=(email == 'alice@example.com' || email == 'bob@example.com') && 'Admin' || 'Viewer'
